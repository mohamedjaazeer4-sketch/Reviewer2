# Reviewer2 environment — ALL OPTIONAL.
# The demo and eval run fully offline with NO keys. Copy to `.env` only if you
# want LLM-written natural-language summaries or live evidence APIs.

# --- LLM layer (for optional natural-language dossier summaries only) ---
# Provider: ollama (default, local) | anthropic | openai | gemini | none
REVIEWER2_LLM_PROVIDER=ollama

# Local (Ollama) — run `ollama serve` and `ollama pull llama3.1` (or mistral, qwen2.5)
REVIEWER2_OLLAMA_MODEL=llama3.1
REVIEWER2_OLLAMA_HOST=http://localhost:11434

# Cloud (only used if REVIEWER2_LLM_PROVIDER matches and key is set)
ANTHROPIC_API_KEY=
REVIEWER2_ANTHROPIC_MODEL=claude-3-5-sonnet-latest

OPENAI_API_KEY=
REVIEWER2_OPENAI_MODEL=gpt-4o-mini

GEMINI_API_KEY=
REVIEWER2_GEMINI_MODEL=gemini-1.5-flash

# --- Evidence layer ---
# Provider: fixtures (default, offline) | live (real ClinVar/gnomAD/VEP APIs)
REVIEWER2_EVIDENCE_PROVIDER=fixtures
# Required by NCBI when using live providers; be polite with rate limits.
NCBI_EMAIL=
NCBI_API_KEY=
